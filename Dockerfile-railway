# Railway用Dockerfile
FROM python:3.10-slim

WORKDIR /opt/xiaozhi-esp32-server

# システム依存関係のインストール
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libopus-dev \
    libopus0 \
    libsndfile1 \
    libsndfile1-dev \
    ffmpeg \
    libavcodec-dev \
    libavformat-dev \
    libavutil-dev \
    libssl-dev \
    libffi-dev \
    python3-dev \
    curl \
    unzip \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Python依存関係のインストール
COPY main/xiaozhi-server/requirements.txt .

# Increase pip timeout and ensure build toolchain is available
ENV PIP_DEFAULT_TIMEOUT=120
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Pre-install heavy native wheels (CPU builds) to reduce build-time failures.
# Adjust or remove if you need CUDA-enabled wheels.
RUN pip install --no-cache-dir "torch==2.2.2+cpu" -f https://download.pytorch.org/whl/cpu/torch_stable.html || true
RUN pip install --no-cache-dir "torchaudio==2.2.2+cpu" -f https://download.pytorch.org/whl/cpu/torch_stable.html || true

RUN pip install --no-cache-dir -r requirements.txt

# アプリケーションコードのコピー
COPY main/xiaozhi-server .

# 必要なディレクトリの作成と基本設定
RUN mkdir -p tmp data /opt/models/sherpa_sense_voice && \
    cp -f config_railway.yaml config.yaml && \
    /bin/sh -lc 'printf "manager-api:\n  url: \"\"\n  secret: \"\"\n" > data/.config.yaml'

## 以前は起動時にエントリポイントでモデルを取得していたが、
## 現在はクラウドASR/LLM/TTSを使用するため不要

# Railway用の設定ファイルは上でコピー済み

# ポート8000を公開
EXPOSE 8000

# アプリケーション起動
CMD ["python", "app.py"]
